"\n"
"App({\n"
"    title: \"Text Editor\",\n"
"    width: 800,\n"
"    height: 600,\n"
"    body: VStack(12, [\n"
"        HStack(8, [\n"
"            Button(\"Open\", () => {\n"
"                openFileDialog((path: string) => {\n"
"                    if (path.length === 0) return\n"
