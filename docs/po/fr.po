#: src/stdlib/container.md:59 src/container/compose.md:219
msgid ""
"```typescript\n"
"import { down } from \"perry/compose\";\n"
"\n"
"async function tearDown(stack: number): Promise<void> {\n"
"    // Default: containers + networks removed; named volumes preserved\n"
"    // so a subsequent `up()` against the same spec resumes from\n"
"    // committed state.\n"
"    await down(stack);\n"
"\n"
"    // Pass `volumes: true` to also drop named volumes â DESTROYS DATA.\n"
"    // Useful for test teardown or for a \"rip and replace\" redeploy.\n"
"    await down(stack, { volumes: true });\n"
"}\n"
"```"
msgstr ""
"```typescript\n"
"import { down } from \"perry/compose\";\n"
"\n"
"async function tearDown(stack: number): Promise<void> {\n"
"    // Par dÃĐfaut : conteneurs + rÃĐseaux supprimÃĐs ; volumes nommÃĐs prÃĐservÃĐs\n"
"    // afin qu'un `up()` ultÃĐrieur avec la mÃŠme spec reprenne depuis\n"
"    // l'ÃĐtat persistÃĐ.\n"
"    await down(stack);\n"
"\n"
"    // Passez `volumes: true` pour supprimer ÃĐgalement les volumes nommÃĐs â DÃTRUIT LES DONNÃES.\n"
"    // Utile pour le nettoyage de tests ou un redÃĐploiement complet.\n"
"    await down(stack, { volumes: true });\n"
"}\n"
"```"

