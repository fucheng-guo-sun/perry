"        )\n"
"        const data = await res.json()\n"
"        return {\n"
"            entries: [{ total: data.total, label: data.label }],\n"
"            reloadPolicy: { after: { minutes: 30 } },\n"
"        }\n"
"    },\n"
"\n"
"    render: (entry) =>\n"
