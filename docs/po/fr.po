"            Text(\"Name:  \" + name),\n"
"        ]),\n"
"        Box({ flexDirection: \"row\" }, [\n"
"            Text(emailFocused ? \"âļ \" : \"  \", { color: \"cyan\" }),\n"
"            Text(\"Email: \" + email),\n"
"        ]),\n"
