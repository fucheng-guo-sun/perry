msgstr "RGBA ในช่วง \\[0, 1\\]"

#: src/ui/widgets.md:647
msgid "`setCornerRadius(w, r)`"
msgstr "`setCornerRadius(w, r)`"

#: src/ui/widgets.md:647
msgid "Rounded corners in points"
msgstr "มุมโค้งมนในหน่วย point"

#: src/ui/widgets.md:648
msgid "`widgetSetOpacity(w, alpha)`"
msgstr "`widgetSetOpacity(w, alpha)`"

#: src/ui/widgets.md:648
msgid "Opacity in \\[0, 1\\]"
msgstr "ความโปร่งใสในช่วง \\[0, 1\\]"

#: src/ui/widgets.md:649
msgid "`widgetSetEnabled(w, flag)`"
msgstr "`widgetSetEnabled(w, flag)`"

#: src/ui/widgets.md:649
msgid "`0` disables, `1` enables"
msgstr "`0` ปิดใช้งาน, `1` เปิดใช้งาน"

#: src/ui/widgets.md:650
msgid "`widgetSetHidden(w, flag)`"
msgstr "`widgetSetHidden(w, flag)`"

#: src/ui/widgets.md:650
msgid "`0` visible, `1` hidden"
msgstr "`0` แสดง, `1` ซ่อน"

#: src/ui/widgets.md:651
msgid "`widgetSetTooltip(w, text)`"
msgstr "`widgetSetTooltip(w, text)`"

#: src/ui/widgets.md:651
