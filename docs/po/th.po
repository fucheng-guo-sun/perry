"    s.replace(\"World\", \"Perry\");\n"
"    s.repeat(3);\n"
"    s.charAt(0);\n"
"    s.padStart(20);\n"
"    s.padEnd(20);\n"
"\n"
"    console.log(`string-methods: ${s.toUpperCase()}`)\n"
"}\n"
"```"
msgstr ""

