msgstr "# 2. ดึงสตริงออกมาไว้ในไฟล์ของภาษา/ภูมิภาค\n"

#: src/i18n/cli.md:42
msgid "# 3. Send locales/de.json to translators (empty values need filling)\n"
msgstr "# 3. ส่ง locales/de.json ให้นักแปล (ค่าที่ว่างต้องเติมให้ครบ)\n"

#: src/i18n/cli.md:44
msgid "# 4. Build — Perry validates everything\n"
msgstr "# 4. Build — Perry จะตรวจสอบทุกอย่าง\n"

