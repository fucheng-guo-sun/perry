#: src/language/supported-features.md:282 src/native-libraries/overview.md:183
#: src/threading/overview.md:314
msgid "Closures"
msgstr "คลอเชอร์"

#: src/language/supported-features.md:284
msgid ""
"```typescript\n"
"function closuresDemo(): void {\n"
"    function makeCounter() {\n"
"        let count = 0;\n"
"        return {\n"
"            increment: () => ++count,\n"
"            get: () => count,\n"
"        };\n"
"    }\n"
"\n"
"    const counter = makeCounter();\n"
"    counter.increment();\n"
"    console.log(counter.get()); // 1\n"
"}\n"
"```"
