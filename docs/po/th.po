#: src/language/supported-features.md:321
msgid "Promises"
msgstr "Promise"

#: src/language/supported-features.md:323
msgid ""
"```typescript\n"
"async function promisesDemo(): Promise<void> {\n"
"    const p = new Promise<number>((resolve, reject) => {\n"
"        resolve(42);\n"
"    });\n"
"\n"
"    p.then((value) => console.log(value));\n"
"\n"
"    // Promise.all\n"
