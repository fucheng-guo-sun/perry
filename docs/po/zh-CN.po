"import moment from \"moment\";\n"
"\n"
"const now = moment();\n"
"console.log(now.format(\"MMMM Do YYYY\"));\n"
"console.log(now.fromNow());\n"
"console.log(moment(\"2025-01-01\").isBefore(now));\n"
"```"
msgstr ""

