"import validator from \"validator\"\n"
"\n"
"console.log(validator.isEmail(\"test@example.com\"))  // true\n"
"console.log(validator.isURL(\"https://example.com\")) // true\n"
"console.log(validator.isUUID(id))                   // true\n"
