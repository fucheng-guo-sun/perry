msgid ""
"```typescript\n"
"// Numeric enums\n"
"enum Direction {\n"
"    Up,\n"
"    Down,\n"
"    Left,\n"
"    Right,\n"
"}\n"
"\n"
"// String enums\n"
"enum Color {\n"
"    Red = \"RED\",\n"
"    Green = \"GREEN\",\n"
"    Blue = \"BLUE\",\n"
"}\n"
"\n"
"const dir = Direction.Up;\n"
"const color = Color.Red;\n"
"```"
msgstr ""
