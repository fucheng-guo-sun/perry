"    \"tar czf /backup/pgdata-$(date +%F).tar.gz -C /data .\"],\n"
"  volumes: [\n"
"    \"app-pgdata:/data:ro\",\n"
"    \"./backups:/backup\",\n"
"  ],\n"
"  rm: true,\n"
