"import sharp from \"sharp\";\n"
"\n"
"const buf = await sharp(\"input.jpg\")\n"
"  .resize(1600, 900)\n"
"  .jpeg({ quality: 80 })\n"
"  .toBuffer();\n"
"\n"
"await sharp(\"input.png\")\n"
"  .resize(300, 200)\n"
"  .toFile(\"output.png\");\n"
