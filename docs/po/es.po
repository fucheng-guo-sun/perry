#: src/language/supported-features.md:7
msgid ""
"```typescript\n"
"function primitives(): void {\n"
"    const n: number = 42;\n"
"    const s: string = \"hello\";\n"
"    const b: boolean = true;\n"
"    const u: undefined = undefined;\n"
