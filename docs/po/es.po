"      \"targets\": {\n"
"        \"macos\":     { \"...\": \"...\" },\n"
"        \"ios\":       { \"...\": \"...\" },\n"
"        \"linux\":     { \"...\": \"...\" },\n"
"        \"windows\":   { \"...\": \"...\" },\n"
