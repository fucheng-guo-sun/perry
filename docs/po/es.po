"```typescript\n"
"// FormatTime: 12h vs 24h based on the active locale.\n"
"const ts = Date.now()\n"
"const formatted = FormatTime(ts)\n"
"console.log(t(\"At: {t}\", { t: formatted }))\n"
"```"
msgstr ""
"```typescript\n"
"// FormatTime: 12h vs 24h based on the active locale.\n"
"const ts = Date.now()\n"
"const formatted = FormatTime(ts)\n"
