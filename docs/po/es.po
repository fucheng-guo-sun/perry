msgstr "Entrada/salida al pasar el cursor (solo escritorio)"

#: src/ui/widgets.md:654
msgid "`widgetSetOnDoubleClick(w, cb)`"
msgstr "`widgetSetOnDoubleClick(w, cb)`"

