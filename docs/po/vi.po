msgstr ""

#: src/cli/perry-toml.md:516
msgid "Set to `1` to disable anonymous telemetry"
msgstr "Đặt thành `1` để tắt telemetry ẩn danh"

#: src/cli/perry-toml.md:517
msgid "`PERRY_NO_UPDATE_CHECK`"
msgstr ""

