msgstr "Các mức xếp hạng được sắp xếp từ cao nhất đến thấp nhất:"

#: src/cli/perry-toml.md:398
msgid "Grade"
msgstr "Mức xếp hạng"

#: src/cli/perry-toml.md:398
msgid "Rank"
msgstr "Thứ hạng"

#: src/cli/perry-toml.md:400
msgid "A"
msgstr "A"

#: src/cli/perry-toml.md:400
msgid "Excellent — no significant findings"
msgstr "Xuất sắc — không có phát hiện đáng kể"

#: src/cli/perry-toml.md:401
msgid "A-"
msgstr "A-"

#: src/cli/perry-toml.md:401
msgid "Very good — minor findings only"
msgstr "Rất tốt — chỉ có các phát hiện nhỏ"

#: src/cli/perry-toml.md:402
msgid "B"
msgstr "B"

#: src/cli/perry-toml.md:402
msgid "Good — some findings"
msgstr "Tốt — có một số phát hiện"

#: src/cli/perry-toml.md:403
msgid "C"
msgstr "C"

#: src/cli/perry-toml.md:403
msgid "Acceptable — moderate findings"
msgstr "Chấp nhận được — phát hiện ở mức vừa phải"

#: src/cli/perry-toml.md:404
msgid "D"
msgstr "D"

#: src/cli/perry-toml.md:404
msgid "Poor — significant findings"
msgstr "Kém — phát hiện đáng kể"

#: src/cli/perry-toml.md:405
msgid "F"
msgstr "F"

#: src/cli/perry-toml.md:405
msgid "Fail — critical findings"
msgstr "Thất bại — phát hiện nghiêm trọng"

#: src/cli/perry-toml.md:407
msgid ""
"Setting `fail_on = \"B\"` means any grade below B (i.e., C, D, or F) will "
"cause the build to fail."
msgstr ""
"Đặt `fail_on = \"B\"` có nghĩa là bất kỳ mức xếp hạng nào thấp hơn B (tức là"
" C, D, hoặc F) sẽ khiến bản build thất bại."

#: src/cli/perry-toml.md:411
msgid "`[verify]`"
msgstr "`[verify]`"

#: src/cli/perry-toml.md:413
msgid "Runtime verification configuration for `perry verify`."
msgstr "Cấu hình xác minh runtime cho `perry verify`."

#: src/cli/perry-toml.md:417
msgid "`https://verify.perryts.com`"
msgstr "`https://verify.perryts.com`"

#: src/cli/perry-toml.md:417
msgid "Verification service endpoint URL"
msgstr "URL endpoint của dịch vụ xác minh"

