"wrapper định dạng `Currency()`."

#: src/cli/perry-toml.md:370
msgid "`{locale}`"
msgstr "`{locale}`"

#: src/cli/perry-toml.md:370
msgid "Currency code for the locale (e.g., `en = \"USD\"`, `de = \"EUR\"`)"
msgstr "Mã tiền tệ cho locale (ví dụ: `en = \"USD\"`, `de = \"EUR\"`)"

#: src/cli/perry-toml.md:374
msgid "`[publish]`"
msgstr "`[publish]`"

#: src/cli/perry-toml.md:376
msgid "Publishing configuration."
msgstr "Cấu hình xuất bản."

#: src/cli/perry-toml.md:380
msgid "`server`"
msgstr "`server`"

