msgstr "Spacer"

#: src/ui/layout.md:95
msgid "A flexible space that expands to fill available room."
msgstr "Một khoảng trống linh hoạt mở rộng để lấp đầy không gian có sẵn."

#: src/ui/layout.md:97
msgid ""
"```typescript\n"
"const toolbar = HStack(8, [\n"
"    Text(\"Left\"),\n"
"    Spacer(),\n"
"    Text(\"Right\"),\n"
"])\n"
"```"
msgstr ""

#: src/ui/layout.md:105
