#: src/api/reference.md:3662 src/api/reference.md:3692
msgid "Classes"
msgstr "Lớp"

#: src/language/supported-features.md:62
msgid ""
"```typescript\n"
"class Animal {\n"
"    name: string;\n"
"\n"
"    constructor(name: string) {\n"
"        this.name = name;\n"
"    }\n"
"\n"
"    speak(): string {\n"
"        return `${this.name} makes a noise`;\n"
"    }\n"
"}\n"
"\n"
"class Dog extends Animal {\n"
"    speak(): string {\n"
"        return `${this.name} barks`;\n"
"    }\n"
"}\n"
"\n"
"// Static methods\n"
"class Counter {\n"
"    private static instance: Counter;\n"
"    private count: number = 0;\n"
"\n"
"    static getInstance(): Counter {\n"
"        if (!Counter.instance) {\n"
"            Counter.instance = new Counter();\n"
"        }\n"
"        return Counter.instance;\n"
"    }\n"
"}\n"
"```"
msgstr ""
"```typescript\n"
"class Animal {\n"
"    name: string;\n"
"\n"
"    constructor(name: string) {\n"
"        this.name = name;\n"
"    }\n"
"\n"
"    speak(): string {\n"
"        return `${this.name} makes a noise`;\n"
"    }\n"
"}\n"
"\n"
"class Dog extends Animal {\n"
"    speak(): string {\n"
"        return `${this.name} barks`;\n"
"    }\n"
"}\n"
"\n"
"// Phương thức static\n"
"class Counter {\n"
"    private static instance: Counter;\n"
"    private count: number = 0;\n"
"\n"
"    static getInstance(): Counter {\n"
"        if (!Counter.instance) {\n"
"            Counter.instance = new Counter();\n"
"        }\n"
"        return Counter.instance;\n"
"    }\n"
"}\n"
"```"

