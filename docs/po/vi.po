"`\"B\"`, `\"C\"`, `\"D\"`, `\"F\"`"

#: src/cli/perry-toml.md:391
msgid "`severity`"
msgstr "`severity`"

#: src/cli/perry-toml.md:391
msgid "`\"all\"`"
msgstr "`\"all\"`"

#: src/cli/perry-toml.md:391
msgid ""
"Filter findings by severity: `\"all\"`, `\"critical\"`, `\"high\"`, "
"`\"medium\"`, `\"low\"`"
msgstr ""
"Lọc các phát hiện theo mức độ nghiêm trọng: `\"all\"`, `\"critical\"`, "
"`\"high\"`, `\"medium\"`, `\"low\"`"

#: src/cli/perry-toml.md:392
msgid "`ignore`"
msgstr "`ignore`"

#: src/cli/perry-toml.md:392
msgid "List of audit rule IDs to suppress (e.g., `[\"RULE-001\", \"RULE-042\"]`)"
msgstr ""
