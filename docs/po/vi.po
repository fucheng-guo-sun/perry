msgid "`default_locale`"
msgstr "`default_locale`"

#: src/cli/perry-toml.md:361
msgid "`\"en\"`"
msgstr "`\"en\"`"

#: src/cli/perry-toml.md:361
msgid "Fallback locale. Used when a key is missing in another locale"
msgstr "Locale dự phòng. Được sử dụng khi một khóa bị thiếu trong locale khác"

#: src/cli/perry-toml.md:362
msgid "`dynamic`"
msgstr "`dynamic`"

#: src/cli/perry-toml.md:362
msgid ""
"`false`: locale set at launch, strings inlined. `true`: locale switchable at"
" runtime"
msgstr ""
"`false`: locale được đặt khi khởi chạy, chuỗi được inline. `true`: locale có"
" thể chuyển đổi tại runtime"

