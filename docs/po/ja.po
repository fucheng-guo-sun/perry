msgid "Toggle a Switch"
msgstr "スイッチを切り替え"

#: src/testing/geisterhand.md:158
msgid ""
"```\n"
"POST /toggle/:handle\n"
"→ {\"ok\":true}\n"
"```"
msgstr ""

