msgstr "スライダーを移動"

#: src/testing/geisterhand.md:141
msgid ""
"```\n"
"POST /slide/:handle\n"
"Content-Type: application/json\n"
"\n"
"{\"value\": 0.75}\n"
"```"
msgstr ""

