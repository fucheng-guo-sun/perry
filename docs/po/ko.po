"```typescript\n"
"// Create directory\n"
"const outDir = join(scratch, \"output\")\n"
"if (!existsSync(outDir)) mkdirSync(outDir)\n"
"\n"
"// Read directory contents\n"
"const files = readdirSync(scratch)\n"
"for (const file of files) {\n"
"    console.log(file)\n"
"}\n"
"\n"
"// Remove an empty directory\n"
"rmdirSync(outDir)\n"
"```"
