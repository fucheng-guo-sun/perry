msgstr "`useApp().exit()`"

#: src/tui/hooks.md:176
msgid "`useStdout().columns` (prop)"
msgstr "`useStdout().columns` (프로퍼티)"

#: src/tui/hooks.md:176
msgid "`useStdout().columns()` (method)"
msgstr "`useStdout().columns()` (메서드)"

#: src/tui/hooks.md:176
