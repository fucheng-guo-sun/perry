msgstr "터치패드 클릭 (Select)"

#: src/platforms/tvos.md:97
msgid "Gamepad button 0 (A) + mouse button 0"
msgstr "게임패드 버튼 0 (A) + 마우스 버튼 0"

#: src/platforms/tvos.md:98
