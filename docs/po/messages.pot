"    textSetColor, textSetFontSize, textSetFontFamily, textSetFontWeight,\n"
"    setCornerRadius, setPadding,\n"
"    widgetAddChild,\n"
"    widgetSetBackgroundColor, widgetSetBackgroundGradient,\n"
"    widgetSetBorderColor, widgetSetBorderWidth,\n"
