"        return a + b;\n"
"    }\n"
"\n"
"    // Optional parameters\n"
"    function greet(name: string, greeting: string = \"Hello\"): string {\n"
"        return `${greeting}, ${name}!`;\n"
"    }\n"
"\n"
"    // Rest parameters\n"
"    function sum(...nums: number[]): number {\n"
"        return nums.reduce((a, b) => a + b, 0);\n"
"    }\n"
"\n"
"    // Arrow functions\n"
"    const double = (x: number) => x * 2;\n"
