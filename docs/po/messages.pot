msgid "Numbers, booleans, null, undefined"
msgstr ""

#: src/threading/overview.md:310 src/threading/parallel-map.md:55
msgid "Zero-cost (64-bit copy)"
msgstr ""

#: src/threading/overview.md:311
msgid "O(n) byte copy"
msgstr ""

#: src/threading/overview.md:312
msgid "O(n) deep copy of elements"
msgstr ""

#: src/threading/overview.md:313
msgid "O(n) deep copy of fields"
msgstr ""

#: src/threading/overview.md:314
msgid "Pointer + captured values"
msgstr ""

#: src/threading/overview.md:315
msgid "`fs` numeric fds / `FileHandle`"
msgstr ""

#: src/threading/overview.md:315
msgid "Thread-affine; reopen by path"
msgstr ""

#: src/threading/overview.md:317
msgid ""
"For numeric workloads — the most common parallelizable tasks — the threading "
"overhead is negligible."
msgstr ""

