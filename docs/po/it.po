#: src/stdlib/fs.md:32
msgid "File Information"
msgstr "Informazioni sui file"

#: src/stdlib/fs.md:41
msgid "Directory Operations"
msgstr "Operazioni sulle directory"

#: src/stdlib/fs.md:43
msgid ""
"```typescript\n"
"// Create directory\n"
"const outDir = join(scratch, \"output\")\n"
"if (!existsSync(outDir)) mkdirSync(outDir)\n"
