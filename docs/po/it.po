"canvas.setFillColor(0.0, 1.0, 0.0, 1.0)\n"
"canvas.beginPath()\n"
"canvas.arc(200, 150, 50, 0, Math.PI * 2)  // x, y, radius, startAngle, endAngle\n"
"canvas.fill()\n"
"```"
msgstr ""

#: src/ui/canvas.md:62
