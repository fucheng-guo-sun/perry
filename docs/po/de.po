"console.log(now.add(7, \"day\").format(\"YYYY-MM-DD\"));\n"
"console.log(now.subtract(1, \"month\").toISOString());\n"
"\n"
"const diff = dayjs(\"2025-12-31\").diff(now, \"day\");\n"
