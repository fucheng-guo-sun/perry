msgstr ""
"`libperry_runtime.a` (Geisterhand-Feature-Build, ersetzt die normale "
"Runtime)"

#: src/testing/geisterhand.md:798
msgid ""
"`libperry_ui_{platform}.a` (geisterhand-featured build, replaces the normal "
"UI lib)"
msgstr ""
"`libperry_ui_{platform}.a` (Geisterhand-Feature-Build, ersetzt die normale "
"UI-Lib)"

#: src/testing/geisterhand.md:799
msgid "`libperry_ui_geisterhand.a` (HTTP server + chaos mode)"
msgstr "`libperry_ui_geisterhand.a` (HTTP-Server + Chaos-Modus)"

#: src/testing/geisterhand.md:801
msgid "Manual Build"
msgstr "Manueller Build"

