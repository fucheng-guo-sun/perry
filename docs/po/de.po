#: src/platforms/overview.md:40
msgid ""
"```typescript\n"
"declare const __platform__: number\n"
"\n"
"// Platform constants:\n"
"// 0 = macOS\n"
"// 1 = iOS\n"
"// 2 = Android\n"
"// 3 = Windows\n"
"// 4 = Linux\n"
"// 5 = Web (browser, --target web / --target wasm)\n"
"// 6 = tvOS\n"
"// 7 = watchOS\n"
"// 8 = visionOS\n"
"\n"
