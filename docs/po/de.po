msgid ""
"```text\n"
"Widget({\n"
"  kind: \"SmallWidget\",\n"
"  // ...\n"
"});\n"
"\n"
"Widget({\n"
"  kind: \"LargeWidget\",\n"
"  // ...\n"
"});\n"
